{
  "name": "@fsarch/server",
  "version": "0.0.1",
  "description": "A TypeScript-based HTTP server library with CLI support",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pagination": {
      "import": "./dist/lib/pagination/index.js",
      "types": "./dist/lib/pagination/index.d.ts"
    },
    "./auth": {
      "import": "./dist/lib/auth/index.js",
      "types": "./dist/lib/auth/index.d.ts"
    },
    "./uac": {
      "import": "./dist/lib/uac/index.js",
      "types": "./dist/lib/uac/index.d.ts"
    }
  },
  "bin": {
    "fsarch-server": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "cli": "node bin/cli.js",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "server",
    "typescript",
    "cli",
    "nodejs",
    "fsarch"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "commander": "^12.0.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.2",
    "express": "^5.2.1",
    "joi": "^18.2.3",
    "jose": "^6.2.3",
    "js-yaml": "^5.0.0",
    "pino": "^10.3.1",
    "serialize-error": "^13.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fsarch/server.git"
  }
}
